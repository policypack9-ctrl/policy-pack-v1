# ==============================================================================
# PolicyPack Environment Variables (.env.example)
# ==============================================================================

# ------------------------------------------------------------------------------
# App General
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PolicyPack"

# ------------------------------------------------------------------------------
# NextAuth / Authentication
# ------------------------------------------------------------------------------
# Generate a secret using: `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET=""
# Use NEXTAUTH_URL if required by specific NextAuth setups, else AUTH_URL
AUTH_URL="http://localhost:3000"

# Optional: Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ------------------------------------------------------------------------------
# Supabase (Database & Auth Adapter)
# ------------------------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"
NEXT_PUBLIC_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# Supabase API keys
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ------------------------------------------------------------------------------
# OpenRouter (AI Models)
# ------------------------------------------------------------------------------
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Model Overrides (Optional)
# OPENROUTER_FREE_RESEARCH_MODEL="google/gemini-flash-1.5"
# OPENROUTER_FREE_DRAFT_MODEL="deepseek/deepseek-chat"
# OPENROUTER_PREMIUM_RESEARCH_MODEL="anthropic/claude-3.7-sonnet"
# OPENROUTER_PREMIUM_DRAFT_MODEL="anthropic/claude-3.7-sonnet"

# ------------------------------------------------------------------------------
# Paddle (Billing / Subscriptions)
# ------------------------------------------------------------------------------
PADDLE_ENVIRONMENT="sandbox" # or "production"
PADDLE_API_KEY=""
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
PADDLE_PRICE_ID=""
PADDLE_STARTER_PRICE_ID=""
PADDLE_PREMIUM_PRICE_ID=""
PADDLE_WEBHOOK_SECRET=""

# ------------------------------------------------------------------------------
# Nodemailer / Notifications (Optional)
# ------------------------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="support@policypack.org"
ADMIN_NOTIFICATION_EMAILS="admin@example.com"
