# PolicyPack Environment Variables

# App Config
NEXT_PUBLIC_APP_NAME="PolicyPack"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# In production, set to https://your-domain.com
# AUTH_URL is required in production for NextAuth
# AUTH_URL="https://your-domain.com"

# NextAuth Secret
# Generate a secret using: npx auth secret
AUTH_SECRET="generate-a-secure-random-string"

# Supabase (PostgreSQL Database)
# Find these in your Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/policypack_dev"

# Google OAuth
# Get these from Google Cloud Console
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Admin Access
ADMIN_EMAIL_ALLOWLIST="admin@example.com"
ADMIN_NOTIFICATION_EMAILS="admin@example.com"
HEALTHCHECK_SECRET="replace-with-a-long-random-string"

# OpenRouter AI (For Policy Generation)
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Optional: Override specific models per tier
# OPENROUTER_FREE_RESEARCH_MODEL="google/gemini-flash-1.5"
# OPENROUTER_FREE_DRAFT_MODEL="deepseek/deepseek-chat"
# OPENROUTER_PREMIUM_RESEARCH_MODEL="anthropic/claude-3.7-sonnet"
# OPENROUTER_PREMIUM_DRAFT_MODEL="anthropic/claude-3.7-sonnet"

# Paddle Billing
PADDLE_ENVIRONMENT="sandbox" # Use "production" for live
NEXT_PUBLIC_PADDLE_ENV="sandbox"
PADDLE_API_KEY="pdl_sdbx_your-api-key"
PADDLE_CLIENT_TOKEN="test_your-client-token"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="test_your-client-token"

# Paddle Price IDs
PADDLE_STARTER_PRICE_ID="pri_starter_id"
PADDLE_PREMIUM_PRICE_ID="pri_premium_id"
PADDLE_PRICE_ID="pri_default_id"

# Paddle Webhook Secret
PADDLE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Launch Promo Campaign
# Set to "false" to end the promotional period instantly (all new users go to free tier)
PROMO_ACTIVE="true"

