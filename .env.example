# PolicyPack environment variables
# Copy this file to .env.local and replace placeholder values.

# -----------------------------------------------------------------------------
# App identity and URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="PolicyPack"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Set one of these in production so NextAuth uses your canonical public URL.
AUTH_URL="http://localhost:3000"
# NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Auth.js / NextAuth
# -----------------------------------------------------------------------------
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-long-random-secret"
# NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# -----------------------------------------------------------------------------
# Supabase / PostgreSQL
# -----------------------------------------------------------------------------
# Preferred keys used by the app:
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Backward-compatible aliases still supported by the code:
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# SUPABASE_SERVICE_KEY="your-service-role-key"

# Local or hosted Postgres connection string for server-side persistence.
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/policypack_dev"
# Optional public DB URL used only by diagnostics/config reporting.
NEXT_PUBLIC_DATABASE_URL=""

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="https://policypack.org/api/admin/linkedin/callback"
# GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# -----------------------------------------------------------------------------
# Admin and healthcheck
# -----------------------------------------------------------------------------
ADMIN_EMAIL_ALLOWLIST="admin@example.com"
ADMIN_NOTIFICATION_EMAILS="admin@example.com"
HEALTHCHECK_SECRET="replace-with-a-long-random-string"

# -----------------------------------------------------------------------------
# OpenRouter
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Optional model overrides. Leave commented unless you need to pin models.
# OPENROUTER_FREE_RESEARCH_MODEL="google/gemini-2.0-flash-001"
# OPENROUTER_FREE_DRAFT_MODEL="deepseek/deepseek-chat"
# OPENROUTER_PREMIUM_RESEARCH_MODEL="google/gemini-2.0-flash-001"
# OPENROUTER_PREMIUM_DRAFT_MODEL="anthropic/claude-sonnet-4-5"
# OPENROUTER_INTERNAL_RESEARCH_MODEL="google/gemini-2.0-flash-001"
# OPENROUTER_INTERNAL_DRAFT_MODEL="anthropic/claude-sonnet-4-5"
# OPENROUTER_RESEARCH_MODEL="google/gemini-2.0-flash-001"
# OPENROUTER_DRAFT_MODEL="deepseek/deepseek-chat"

# -----------------------------------------------------------------------------
# Paddle billing
# -----------------------------------------------------------------------------
PADDLE_ENVIRONMENT="sandbox"
NEXT_PUBLIC_PADDLE_ENV="sandbox"
PADDLE_API_KEY="pdl_sdbx_your-api-key"

# Either configure a static client token or allow the server to generate one.
PADDLE_CLIENT_TOKEN=""
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""

PADDLE_STARTER_PRICE_ID="pri_starter_id"
PADDLE_PREMIUM_PRICE_ID="pri_premium_id"
# Fallback price used when a plan-specific id is not set.
PADDLE_PRICE_ID=""
PADDLE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# -----------------------------------------------------------------------------
# SMTP notifications
# -----------------------------------------------------------------------------
# Use a professional mailbox for support@policypack.org.
# Do not use a personal Gmail sender for user-facing emails.
SMTP_PROVIDER="smtp"
SMTP_HOST="smtp.your-mail-provider.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="support@policypack.org"
SMTP_PASS="replace-with-your-real-smtp-password"
SMTP_FROM="PolicyPack Support <support@policypack.org>"
SMTP_REPLY_TO="support@policypack.org"

# Dedicated founder outreach sender.
OUTREACH_SMTP_PROVIDER="smtp"
OUTREACH_SMTP_HOST="mail.privateemail.com"
OUTREACH_SMTP_PORT="465"
OUTREACH_SMTP_SECURE="true"
OUTREACH_SMTP_USER="founder@policypack.org"
OUTREACH_SMTP_PASS="replace-with-founder-mailbox-password"
OUTREACH_SMTP_FROM="PolicyPack Founder <founder@policypack.org>"
OUTREACH_SMTP_REPLY_TO="founder@policypack.org"

# -----------------------------------------------------------------------------
# Promo flags
# -----------------------------------------------------------------------------
# Set to "false" to end the promotional period instantly.
PROMO_ACTIVE="true"

# -----------------------------------------------------------------------------
# Google Sheets automation (local/admin tooling)
# -----------------------------------------------------------------------------
GOOGLE_SHEETS_SPREADSHEET_ID="19X7R8OlHlJW14CeKVeTCoXY5Nwwt9cR_3HToHGn0TaA"
GOOGLE_SHEETS_SHEET_NAME="Sheet1"
GOOGLE_SHEETS_SERVICE_ACCOUNT_KEY_FILE=".secrets/google-sheets-service-account.json"
